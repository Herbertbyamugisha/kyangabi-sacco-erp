# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────────

# PostgreSQL Database (use Railway/Render free tier)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sacco_db

# JWT Secret (generate a long random string)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_at_least_64_chars

# Session Secret
SESSION_SECRET=replace_this_with_another_long_random_secret

# Google OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-app-name.railway.app/auth/google/callback

# App URL (your Railway/Render domain after deploy)
APP_URL=https://your-app-name.railway.app
FRONTEND_URL=https://your-app-name.railway.app

# Email (for notifications — use Gmail App Password)
MAIL_USER=saccokyangabi@gmail.com
MAIL_PASS=your_gmail_app_password

# Port
PORT=3000

# Environment
NODE_ENV=production

# Allowed Gmail domains/accounts for registration
# Leave blank to allow all Gmail accounts, or comma-separate specific emails
ALLOWED_EMAILS=

# Admin email (this user gets admin role automatically)
ADMIN_EMAIL=kyangabiresort@gmail.com
